# .env.example
APP_ENV=development
APP_DEBUG=false

# SQLite
DATABASE__URL=sqlite+aiosqlite:///./data/news_parser.db

# Chroma
CHROMA__HOST=localhost
CHROMA__PORT=8000
CHROMA__PERSIST_DIR=./data/chroma
CHROMA__COLLECTION_ARTICLES=article_embeddings
CHROMA__COLLECTION_CRITERIA=criteria_embeddings

# Embedding model
EMBEDDING__MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING__DIMENSIONS=384
EMBEDDING__BATCH_SIZE=64
EMBEDDING__NORMALIZE=true

# Filtering
FILTERING__DEFAULT_THRESHOLD=0.40
FILTERING__COLD_START_PHRASES_COUNT=8
FILTERING__WEIGHTS__EMBEDDING=0.60
FILTERING__WEIGHTS__KEYWORD=0.25
FILTERING__WEIGHTS__FEEDBACK=0.15
FILTERING__FEEDBACK__MIN_COUNT_FOR_BOOST=10
FILTERING__FEEDBACK__BOOST_EMBEDDING=0.55
FILTERING__FEEDBACK__BOOST_KEYWORD=0.20
FILTERING__FEEDBACK__BOOST_FEEDBACK=0.25

# Dedup
DEDUP__MINHASH_THRESHOLD=0.85
DEDUP__MINHASH_NUM_PERM=128

# Feed
FEED__MAX_ITEMS=50
FEED__RECENCY_DECAY_HOURS=24.0
FEED__SNAPSHOT_TTL_MINUTES=30

# Task queue
TASK_QUEUE__BACKEND=background   # celery | background
TASK_QUEUE__CELERY_BROKER=redis://localhost:6379/0
TASK_QUEUE__CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Workers
WORKERS__FETCH_INTERVAL_SECONDS=300
WORKERS__MAX_RETRIES=3
WORKERS__PIPELINE_CONCURRENCY=4

# Auth
AUTH__SECRET_KEY=change-me-in-production-min-32-chars
AUTH__ALGORITHM=HS256
AUTH__ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH__REFRESH_TOKEN_EXPIRE_DAYS=30

# LLM (cold start)
LLM__PROVIDER=anthropic          # anthropic | openai
LLM__API_KEY=sk-ant-...
LLM__MODEL=claude-haiku-4-5-20251001
LLM__MAX_TOKENS=512

# Scoring
SCORING__BM25_MIN_THRESHOLD=0.10
SCORING__BM25_WEIGHT=0.25
SCORING__EMBED_WEIGHT=0.60
SCORING__TAGGER_THRESHOLD=0.40